DATABASE_URL=sqlite:///./data/{{projectName}}.db
SECRET_KEY={{secretKey}}
CORS_ORIGINS=["http://localhost:5173"]

# Digital Ocean Spaces (for Litestream backup)
# LITESTREAM_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# LITESTREAM_S3_BUCKET=your-bucket
# LITESTREAM_ACCESS_KEY_ID=your-key
# LITESTREAM_SECRET_ACCESS_KEY=your-secret

# Deployment
# DOMAIN=your-domain.com
# DEPLOY_USER=deploy
